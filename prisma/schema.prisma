// ============================================================================
//  apricot-budget — Prisma schema
//  PostgreSQL 16 · Decimal(14,2) money · UUIDs · pgcrypto + pg_trgm + citext
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, citext]
}

// ---------------------------------------------------------------------------
//  Enums
// ---------------------------------------------------------------------------

enum AccountType {
  ASSET
  LIABILITY
}

enum AccountSubtype {
  // Assets
  CHECKING
  SAVINGS
  INVESTMENT
  REAL_ESTATE
  VEHICLE
  OTHER_ASSET
  // Liabilities
  CREDIT_CARD
  MORTGAGE
  LOAN
  LINE_OF_CREDIT
  OTHER_LIABILITY
}

enum CategoryDirection {
  EXPENSE
  INCOME
  TRANSFER
  NEUTRAL
}

enum MappingMatchType {
  EXACT       // description == pattern (case-insensitive via citext)
  CONTAINS    // description ILIKE '%pattern%'
  PREFIX      // description ILIKE 'pattern%'
  REGEX       // description ~* pattern
}

enum ImportStatus {
  PENDING     // uploaded, not yet confirmed
  MAPPING     // user is reviewing category mappings
  CONFIRMED   // rows have been persisted to transactions
  CANCELLED
}

enum BudgetDirection {
  EXPENSE
  INCOME
}

enum BudgetRecurrence {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
  ONCE
}

// Statut d'une occurrence projetée dans le calendrier de prévision.
//   PROJECTED  — occurrence attendue, non encore rapprochée
//   REALIZED   — matchée avec une vraie transaction (via ReconciliationService)
//   SKIPPED    — attendue mais non survenue (le paiement n'a pas eu lieu)
//   CANCELLED  — supprimée manuellement par l'utilisateur pour cette date
enum ScheduledInstanceStatus {
  PROJECTED
  REALIZED
  SKIPPED
  CANCELLED
}

// ---------------------------------------------------------------------------
//  Users
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.Citext
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  locale       String   @default("fr-CA")
  currency     String   @default("CAD")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  accounts         Account[]
  categories       Category[]
  transactions     Transaction[]
  csvImports       CsvImport[]
  csvMappingRules  CsvMappingRule[]
  budgetItems      BudgetItem[]

  @@map("users")
}

// ---------------------------------------------------------------------------
//  Accounts (Actifs / Passifs)
//  A single table holds both assets and liabilities. `type` decides which side.
// ---------------------------------------------------------------------------

model Account {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  name           String
  type           AccountType
  subtype        AccountSubtype
  institution    String?        // "Desjardins", "TD", "Tesla loan", ...
  accountNumber  String?        @map("account_number") // last 4 digits only
  initialBalance     Decimal   @default(0) @map("initial_balance") @db.Decimal(14, 2)
  // Date de référence du solde initial. Point d'ancrage pour la projection :
  // le ForecastService part de ce solde à cette date, applique les transactions
  // réelles postérieures, puis les ScheduledInstance à venir.
  initialBalanceDate DateTime  @default(dbgenerated("CURRENT_DATE")) @map("initial_balance_date") @db.Date
  currency       String         @default("CAD")
  color          String?        // hex or CDS ramp name, for UI
  icon           String?        // Tabler icon name
  isArchived     Boolean        @default(false) @map("is_archived")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  csvImports   CsvImport[]
  budgetItems  BudgetItem[]

  @@index([userId, isArchived])
  @@index([userId, type])
  @@map("accounts")
}

// ---------------------------------------------------------------------------
//  Categories
//  Default categories are seeded with isSystem = true (undeletable).
//  User-created categories are private (userId set) and deletable.
// ---------------------------------------------------------------------------

model Category {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?           @map("user_id") @db.Uuid  // null = global/system category
  name       String            @db.Citext
  slug       String            @db.Citext                // stable key, used by CSV rules
  direction  CategoryDirection @default(EXPENSE)
  icon       String?
  color      String?           // CDS ramp name (coral, teal, ...) or hex
  isSystem   Boolean           @default(false) @map("is_system")
  sortOrder  Int               @default(0) @map("sort_order")
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  user            User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  splits          TransactionSplit[]
  csvMappingRules CsvMappingRule[]
  budgetItems     BudgetItem[]

  // A user cannot have two categories with the same slug.
  // System categories share userId=NULL and their slug must be globally unique too.
  @@unique([userId, slug], name: "uq_category_user_slug")
  @@index([userId])
  @@map("categories")
}

// ---------------------------------------------------------------------------
//  Transactions
//  Amount is a *signed* Decimal:
//    - negative = money OUT (debit)
//    - positive = money IN  (credit)
//  This mirrors the accounting convention used by the frontend calendar.
// ---------------------------------------------------------------------------

model Transaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  accountId       String   @map("account_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  csvImportId     String?  @map("csv_import_id") @db.Uuid

  // Transfer pairing — self-reference. When set, points at the counterpart
  // transaction in another account (e.g. -500 on checking ↔ +500 on the CC).
  // Uniqueness is enforced at the DB level by a partial UNIQUE index (see
  // migration `20260720000000_splits_and_transfers`). We don't declare it as
  // Prisma `@unique` here because Prisma would generate a full unique
  // constraint — the partial form is the correct semantics (many rows may
  // legitimately have NULL). Populated by the (future) transfer-matching
  // flow; NULL for regular expenses/income.
  linkedTransactionId String? @map("linked_transaction_id") @db.Uuid

  postedAt        DateTime @map("posted_at") @db.Date          // transaction date, no time
  description     String   @db.Citext                          // raw bank libellé
  amount          Decimal  @db.Decimal(14, 2)                  // signed
  importedBalance Decimal? @map("imported_balance") @db.Decimal(14, 2)  // "Solde" from CSV, for checksum
  notes           String?
  externalId      String?  @map("external_id")                 // bank ref if provided, for dedup
  isRecurring     Boolean  @default(false) @map("is_recurring")

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  csvImport CsvImport? @relation(fields: [csvImportId], references: [id], onDelete: SetNull)

  // Split lines. Every transaction has ≥1 split whose amounts sum to
  // `transaction.amount`. Populated in parallel with `categoryId` starting
  // in Phase 1; reads still use `categoryId` until Phase 2 flips over.
  splits    TransactionSplit[]

  // Self-relation for transfer pairing. `linkedTransaction` = the counterpart
  // side of the transfer. `linkingTransactions` is the reverse — logically
  // always ≤1 row thanks to the UNIQUE index, exposed as an array by Prisma.
  linkedTransaction   Transaction?  @relation("TransactionTransferLink", fields: [linkedTransactionId], references: [id], onDelete: SetNull)
  linkingTransactions Transaction[] @relation("TransactionTransferLink")

  // Réverse-lien depuis ScheduledInstance quand la transaction rapproche une
  // occurrence projetée. Une transaction ne peut satisfaire qu'une occurrence
  // à la fois (contrainte UNIQUE côté ScheduledInstance.matchedTransactionId).
  matchedScheduledInstance ScheduledInstance? @relation("ScheduledInstanceMatch")

  // Fast calendar queries (30/7 day sliding windows).
  @@index([userId, postedAt(sort: Desc)])
  @@index([accountId, postedAt(sort: Desc)])
  @@index([categoryId])
  @@index([csvImportId])
  // Dedup guard: same account + same date + same amount + same external ref.
  @@unique([accountId, postedAt, amount, externalId], name: "uq_tx_dedup")
  @@map("transactions")
}

// ---------------------------------------------------------------------------
//  TransactionSplit
//  Allows a single transaction to be split across multiple categories, e.g.
//  a Costco receipt covering groceries + pharmacy + clothing. Every
//  transaction has ≥1 split; the sum of split amounts equals the parent
//  transaction's amount (application-level invariant, not DB-enforced).
//  `amount` is signed, same convention as `Transaction.amount`.
// ---------------------------------------------------------------------------

model TransactionSplit {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)   // signed
  notes         String?
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([categoryId])
  @@map("transaction_splits")
}

// ---------------------------------------------------------------------------
//  CSV imports
//  One row per uploaded file. Transactions reference it so we can undo an
//  import atomically.
// ---------------------------------------------------------------------------

model CsvImport {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  accountId      String       @map("account_id") @db.Uuid
  filename       String
  fileHash       String       @map("file_hash")                 // sha256, prevents re-import
  rowCount       Int          @map("row_count")
  mappedCount    Int          @default(0) @map("mapped_count")
  status         ImportStatus @default(PENDING)
  rawPayload     Json?        @map("raw_payload")               // parsed rows, kept until CONFIRMED
  errors         Json?                                          // per-row parsing errors
  uploadedAt     DateTime     @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  confirmedAt    DateTime?    @map("confirmed_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, fileHash], name: "uq_import_hash")
  @@index([userId, uploadedAt(sort: Desc)])
  @@map("csv_imports")
}

// ---------------------------------------------------------------------------
//  CSV mapping rules — description → category
//  Learned automatically as the user confirms mappings, or created by hand.
//  Ordered by (priority DESC, timesUsed DESC).
// ---------------------------------------------------------------------------

model CsvMappingRule {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  categoryId     String           @map("category_id") @db.Uuid
  matchType      MappingMatchType @default(EXACT) @map("match_type")
  pattern        String           @db.Citext                    // description or fragment
  priority       Int              @default(100)                 // higher = evaluated first
  autoCreated    Boolean          @default(false) @map("auto_created")
  timesUsed      Int              @default(0) @map("times_used")
  lastUsedAt     DateTime?        @map("last_used_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, matchType, pattern], name: "uq_rule_user_pattern")
  @@index([userId, priority(sort: Desc)])
  // pg_trgm GIN index on `pattern` is created in the migration SQL (see 0001_init).
  @@map("csv_mapping_rules")
}

// ---------------------------------------------------------------------------
//  Budget items — recurring planned cashflows tied to a category.
//  `amount` is always positive; `direction` gives the sign.
//  Correlation with real transactions is done at query time by category.
// ---------------------------------------------------------------------------

model BudgetItem {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  categoryId  String            @map("category_id") @db.Uuid
  accountId   String?           @map("account_id") @db.Uuid
  name        String
  direction   BudgetDirection
  amount      Decimal           @db.Decimal(14, 2)
  currency    String            @default("CAD")
  recurrence  BudgetRecurrence
  anchorDate  DateTime          @map("anchor_date") @db.Date
  endDate     DateTime?         @map("end_date") @db.Date

  // Prévision cashflow — RRULE optionnelle (RFC 5545) qui *remplace* l'enum
  // `recurrence` quand elle est présente. Permet des cadences complexes :
  //   FREQ=MONTHLY;BYMONTHDAY=1,15         (bi-mensuel jours fixes)
  //   FREQ=WEEKLY;BYDAY=FR;INTERVAL=2      (aux 2 vendredis, paie)
  //   FREQ=MONTHLY;BYDAY=-1FR              (dernier vendredi du mois)
  rrule       String?
  // Ancre RRULE (DTSTART). Fallback = anchorDate si null.
  dtstart     DateTime?         @map("dtstart") @db.Date
  // Si vrai, la ScheduledInstance passe automatiquement à REALIZED quand
  // une transaction importée matche. Sinon l'utilisateur confirme manuellement.
  autoConfirm Boolean           @default(true) @map("auto_confirm")
  // Score 0-100 de fiabilité de la prévision (utilisé par le détecteur auto).
  confidence  Int               @default(100)

  isActive    Boolean           @default(true) @map("is_active")
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  account  Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  scheduledInstances ScheduledInstance[]

  @@index([userId, isActive])
  @@index([userId, categoryId])
  @@map("budget_items")
}

// ---------------------------------------------------------------------------
//  ScheduledInstance — occurrences matérialisées d'un BudgetItem
//  Une ligne = une occurrence future ou passée dans le calendrier de prévision.
//  Créée à la volée par le ForecastService et persistée dès qu'elle est
//  modifiée (montant ajusté, statut REALIZED/SKIPPED, transaction matchée).
//  Les projections purement futures peuvent rester non-persistées.
// ---------------------------------------------------------------------------

model ScheduledInstance {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetItemId   String                  @map("budget_item_id") @db.Uuid
  expectedDate   DateTime                @map("expected_date") @db.Date
  expectedAmount Decimal                 @map("expected_amount") @db.Decimal(14, 2)  // signé, comme Transaction
  status         ScheduledInstanceStatus @default(PROJECTED)
  matchedTransactionId String?           @unique @map("matched_transaction_id") @db.Uuid
  notes          String?
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  budgetItem         BudgetItem   @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  matchedTransaction Transaction? @relation("ScheduledInstanceMatch", fields: [matchedTransactionId], references: [id], onDelete: SetNull)

  // Une seule occurrence par jour par règle : évite les doublons de projection.
  @@unique([budgetItemId, expectedDate], name: "uq_instance_item_date")
  @@index([expectedDate, status])
  @@map("scheduled_instances")
}
