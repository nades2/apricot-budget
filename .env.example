# =============================================================================
#  apricot-budget · environment
#  Copy this file to `.env` and fill in the values for your environment.
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
# Serveur local partagé (10.0.0.227)
#   port 5432 = prod  |  port 5433 = dev/test
DATABASE_URL="postgresql://admin:admin1234@10.0.0.227:5433/apricot_budget_dev?schema=public&sslmode=disable"

# --- Backend -----------------------------------------------------------------
NODE_ENV=development
PORT=3000
# JWT_SECRET : minimum 32 caractères en production. Générer avec :
#   openssl rand -base64 48
# Le backend refuse de démarrer si absent ou = 'please-change-me' en prod.
JWT_SECRET=please-change-me
JWT_REFRESH_SECRET=please-change-me-too
CORS_ORIGIN=http://localhost:5173

# INVITE_CODES : liste de codes acceptés pour /auth/register, séparés par ",".
# Si vide/absent : registration ouverte à tous (mode dev).
# Si défini : /auth/register exige inviteCode ∈ liste (mode prod).
# Exemple prod : INVITE_CODES=abc123,ami-julie-2026,ami-marc-2026
INVITE_CODES=

# --- Frontend ----------------------------------------------------------------
VITE_API_URL=http://localhost:3000/api
